PORT=6258
ADMIN_PIN=123456
ARIA2_RPC_URL=http://127.0.0.1:6800/jsonrpc
ARIA2_RPC_SECRET=
# GOFILE_API_TOKEN=
PIXELDRAIN_API_TOKEN=
DEFAULT_STORAGE_PROVIDER=pixeldrain
DATA_DIR=./data
JWT_SECRET=gotouch_secret_key_change_in_production

# Aria2c Executable & Auto-Start Settings
# Set AUTO_START_ARIA2=true to automatically spawn aria2c if daemon is not running.
# Set ARIA2_PATH to explicit path (e.g. C:\Program Portable\aria2c\aria2c.exe on Windows, or aria2c on Linux VPS).
AUTO_START_ARIA2=true
ARIA2_PATH=aria2c

# Debug Logging Mode (Set true for verbose terminal output)
DEBUG=false
